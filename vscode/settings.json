{
    "godotTools.editorPath.godot4": "/usr/bin/Godot_v4.4.1-stable_linux.x86_64",
    "godotTools.formatter.denseFunctionParameters": true,
    "editor.fontSize": 15,
    "vim.easymotion": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": false,
    "vim.hlsearch": true,
    "vim.autoindent": true,
    "vim.leader": "<space>",

    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["|"],
            "commands": ["workbench.action.splitEditorRight"]
        },
        {
            "before": ["_"],
            "commands": ["workbench.action.splitEditorDown"]
        },
        {
            "before": ["<leader>", "w", "c"],
            "commands": ["workbench.action.closeActiveEditor"]
        },
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.action.toggleSidebarVisibility"]
        },
        {
            "before": ["<leader>", "f", "f"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "f", "w"],
            "commands": ["workbench.action.findInFiles"],
        },
        {
            "before": ["K"],
            "commands": ["editor.action.showDefinitionPreviewHover"]
        },
        {
            "before": ["<leader>", "w", "h"],
            "commands": ["workbench.action.focusLeftGroup"]
        },
        {
            "before": ["<leader>", "w", "l"],
            "commands": ["workbench.action.focusRightGroup"]
        },
        {
            "before": ["<leader>","w", "k"],
            "commands": ["workbench.action.focusAboveGroup"]
        },
        {
            "before": ["<leader>", "w", "j"],
            "commands": ["workbench.action.focusBelowGroup"]
        },
        {
            "before": ["<C-right>"],
            "commands": ["workbench.action.increaseViewWidth"]
        },
        {
            "before": ["<C-left>"],
            "commands": ["workbench.action.decreaseViewWidth"]
        }
    ],

    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false
    },

    "workbench.colorTheme": "Everforest Pro Dark Vibrant",
    "redhat.telemetry.enabled": false,
    "workbench.activityBar.location": "top",
    "java.imports.gradle.wrapper.checksums": [
        {
            "sha256": "2c23278a62dc9f96ab11bee897d9f53e6479d6419135e4560ce822a6431df5e5",
            "allowed": true
        }
    ],
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.cursorBlinking": "smooth",
    "editor.fontFamily": "0xProto Nerd Font Propo",
    "editor.stickyScroll.enabled": false,
    "editor.minimap.enabled": false,
    "terminal.integrated.fontFamily": "Iosevka",
    "svelte.enable-ts-plugin": true,
    "workbench.browser.showInTitleBar": false,
    "window.menuBarVisibility": "compact",
    "fennel-lsx.server-version": "bundled",
    "workbench.editor.editorActionsLocation": "hidden",
    "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
    "window.density.editorTabHeight": "compact",
    "editor.stickyTabStops": true,
}